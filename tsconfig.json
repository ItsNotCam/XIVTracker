{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,
		"allowJs": true,

		/* types */
		"typeRoots": ["./node_modules/@types", "@types"],

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "strictFunctionTypes": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,

		/* Custom @app directory */
		"baseUrl": ".",
		"paths": { 
			"*": ["@types/*"],
			// "@electron-lib/*": ["electron/libs/*"],
			// "@electron/*": ["electron/*"]

			"@backend-lib/*": ["electron/libs/*"],
			"@backend/*": ["electron/*"],

			// ui
			"@ui/*": ["ui/src/*"],
			"@components/*": ["ui/src/components/*"],
			"@assets/*": ["ui/src/assets/*"],
			"@layout/*": ["ui/src/layout/*"],
			"@styles/*": ["ui/styles/*"],
			"@xiv-types": ["types/index.ts"]
		},
		"rootDir": ".",
		"outDir": "./dist"
  },
  "include": [
		"electron",
		"ui",
		"@types/**/*.d.ts", 
		// "@types/idisposable.d.ts", 
		// "@types/db.ts",
		// "@types/recipe.ts",
		// "@types/ez-net.ts",
		// "@types/event-base.d.ts",
		// "@types/disposable.d.ts",  
		"electron/libs/providers/.RecipeProvider.ts.old", "types/ipc.types.ts", "schemas/ez-db.d.ts", "schemas/types.ts", "types/json-rpc-types.ts", "types/recipe.d.ts", 
	],
  "references": [{ "path": "./tsconfig.node.json" }],
}